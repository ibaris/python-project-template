graft src
graft resources
graft tests

{% if cookiecutter.github_actions == 'yes' -%}
graft .github
{% endif -%}
{% if cookiecutter.pre_commit == "yes" -%}
include .pre-commit-config.yaml
{% endif -%}
{% if cookiecutter.sphinx_docs == 'yes' and 'readthedocs' in cookiecutter.sphinx_docs_hosting -%}
include .readthedocs.yml
{% endif -%}
include pyproject.toml
{% if cookiecutter.include_docker == 'yes' -%}
include Dockerfile
include .devcontainer.json
include .dockerignore
{% endif -%}

include ./src/.info/*
include ./resources/envs/*
include ./resources/scripts/*
include CONTRIBUTING.md
include LICENSE
include README.md
include ./.vscode/*

global-exclude *.py[cod] __pycache__/* *.so *.dylib
